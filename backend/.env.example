# Server
PORT=5000
NODE_ENV=development

# Frontend origin(s) for CORS — required in production
CLIENT_URL=http://localhost:5173
# Comma-separated extra origins (preview URLs, custom domains)
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/portfolio?retryWrites=true&w=majority
MONGO_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=1
MONGO_SERVER_SELECTION_TIMEOUT=10000
MONGO_SOCKET_TIMEOUT=45000

# JWT
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRES=1d
JWT_REMEMBER_EXPIRES=30d

# Admin seed (used only when no admin exists in the database)
ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=ReplaceWithAStrongPassword123!
ADMIN_NAME=Ahmad

# SMTP (contact form notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Ahmad Stack Portfolio <noreply@your-domain.com>"
CONTACT_NOTIFY_EMAIL=your-admin@example.com

# Vercel Blob (required for file uploads on Vercel — create in Vercel Dashboard → Storage → Blob)
BLOB_READ_WRITE_TOKEN=

# Auth cookies when frontend/API are on different domains
COOKIE_CROSS_SITE=false

# Rate limiting
API_RATE_LIMIT_MAX=300
